<Window x:Class="ArmaduraSuperiorLosaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Armadura Superior Losas"
        Width="500"
        Height="430"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFBFBFBF">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="110"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFBFBFBF" BorderBrush="Black" BorderThickness="1">
            <TextBlock Text="Armadura Superior Losas"
                       Foreground="Red"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Background="#FFD0D0D0" BorderBrush="Black" BorderThickness="1" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
                           Text="Vano 1"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Largo:"
                           Foreground="Red"
                           VerticalAlignment="Center"
                           Margin="0,0,5,0"/>
                <TextBox Grid.Row="1" Grid.Column="1"
                         x:Name="LargoVano1TextBox"
                         Width="70"
                         HorizontalAlignment="Left"/>

                <Button Grid.Row="1" Grid.Column="2"
                        x:Name="SeleccionarVano1Button"
                        Content="Seleccionar"
                        Margin="15,0"
                        Padding="10,2"/>

                <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="L1:"
                               Foreground="Red"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0"/>
                    <TextBox x:Name="L1Vano1TextBox"
                             Width="70"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#FFD0D0D0" BorderBrush="Black" BorderThickness="1" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
                           Text="Vano 2"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Largo:"
                           Foreground="Red"
                           VerticalAlignment="Center"
                           Margin="0,0,5,0"/>
                <TextBox Grid.Row="1" Grid.Column="1"
                         x:Name="LargoVano2TextBox"
                         Width="70"
                         HorizontalAlignment="Left"/>

                <Button Grid.Row="1" Grid.Column="2"
                        x:Name="SeleccionarVano2Button"
                        Content="Seleccionar"
                        Margin="15,0"
                        Padding="10,2"/>

                <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="L1:"
                               Foreground="Red"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0"/>
                    <TextBox x:Name="L1Vano2TextBox"
                             Width="70"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="#FFD0D0D0" BorderBrush="Black" BorderThickness="1" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Diámetro de barra:"
                           Foreground="Red"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox Grid.Row="0" Grid.Column="1"
                          x:Name="DiametroPrincipalComboBox"
                          Background="Yellow"
                          Height="24"
                          HorizontalAlignment="Stretch"/>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Diámetro de barra:"
                           Foreground="Red"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox Grid.Row="2" Grid.Column="1"
                          x:Name="DiametroSecundarioComboBox"
                          Height="24"
                          HorizontalAlignment="Stretch"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="#FFBFBFBF" BorderBrush="Black" BorderThickness="1" Padding="10">
            <Button x:Name="AplicarRecorridoButton"
                    Content="Aplicar recorrido"
                    FontWeight="Bold"
                    Foreground="Red"
                    Width="180"
                    Height="40"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
        </Border>

    </Grid>
</Window>
